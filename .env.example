# ── Contacto / envío de emails (Gmail SMTP con App Password) ──────
# 1. En tu cuenta de Google activa la Verificación en 2 pasos.
# 2. Crea una "Contraseña de aplicación": https://myaccount.google.com/apppasswords
# 3. Pega aquí el correo y la contraseña de 16 caracteres (sin espacios).
SMTP_FROM_EMAIL="tu-correo@gmail.com"
SMTP_APP_PASSWORD="xxxxxxxxxxxxxxxx"

# Destinatario principal del formulario (separar por coma si son varios)
CONTACT_TO=jukopila.giovanny15@gmail.com
# Destinatarios en copia (CC)
CONTACT_CC=jukopila.yango@gmail.com
